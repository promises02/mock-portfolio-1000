# GEMINI_API_KEY: Required for Gemini AI API calls on the server.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GOOGLE_GEMINI_API_KEY: Required for client-side asset validation (Gemini).
VITE_GOOGLE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_ADMIN_PASSWORD: Admin mode login password (client-side gate for mock portfolio).
VITE_ADMIN_PASSWORD="1234"

# ADMIN_PASSWORD: Server-side admin API password (defaults to VITE_ADMIN_PASSWORD or 1234).
ADMIN_PASSWORD="1234"

# FIREBASE_SERVICE_ACCOUNT: (Vercel/Render) Firebase Admin 서비스 계정 JSON 전체.
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성 → JSON을 한 줄로 붙여넣기.
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# REALTIME_PRICE_CRON: (optional) node-schedule cron for price refresh. Default: */10 * * * *
# REALTIME_PRICE_CRON="*/10 * * * *"
